# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather

# Pyrogram (MTProto) — required for files > 20 MB
# Get these at https://my.telegram.org
PYROGRAM_API_ID=your_api_id
PYROGRAM_API_HASH=your_api_hash

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
MONGO_DB=nxtup

# Temp directory for downloads
TEMP_DIR=temp

# Log channel — every upload is silently posted here (optional)
# Add the bot as admin to a private channel, get its -100... ID
LOG_CHANNEL_ID=-100xxxxxxxxxx

# Admin user IDs — comma-separated, allowed to use /broadcast and /stats
# These commands are hidden and invisible to everyone else
ADMIN_IDS=123456789,987654321
